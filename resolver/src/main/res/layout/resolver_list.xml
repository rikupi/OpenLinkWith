<?xml version="1.0" encoding="utf-8"?>
<com.tasomaniac.openwith.resolver.ResolverDrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/contentPanel"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  app:maxCollapsedHeight="192dp"
  app:maxCollapsedHeightSmall="56dp"
  app:resolverMaxWidth="@dimen/resolver_max_width">

  <!-- Single container for blur -->
  <LinearLayout
    android:id="@+id/sheet_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_shape"
    android:orientation="vertical"
    app:layout_alwaysShow="true">

    <!-- Drag handle -->
    <View
      android:layout_width="36dp"
      android:layout_height="4dp"
      android:layout_gravity="center_horizontal"
      android:layout_marginTop="8dp"
      android:layout_marginBottom="4dp"
      android:background="@drawable/resolver_drag_handle" />

    <include layout="@layout/resolver_link_info" />

    <!-- Title -->
    <TextView
      android:id="@+id/title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="start|center_vertical"
      android:minHeight="48dp"
      android:paddingHorizontal="24dp"
      android:paddingVertical="8dp"
      android:textColor="?android:attr/textColorPrimary"
      android:textSize="16sp"
      android:textStyle="bold" />

    <!-- App list -->
    <androidx.recyclerview.widget.RecyclerView
      android:id="@+id/resolver_list"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:clipToPadding="false"
      android:divider="@null"
      android:paddingBottom="8dp"
      android:scrollbarStyle="outsideOverlay"
      app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
      android:orientation="vertical" />

    <!-- Action buttons -->
    <LinearLayout
      android:id="@+id/button_bar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingHorizontal="16dp"
      android:paddingVertical="8dp"
      android:visibility="gone">

      <Button
        android:id="@+id/button_once"
        style="?attr/buttonBarButtonStyle"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:enabled="false"
        android:text="@string/activity_resolver_use_once"
        android:textAllCaps="false"
        android:textAppearance="@style/Resolver.ButtonText" />

      <!-- Vertical separator between buttons -->
      <View
        android:layout_width="1dp"
        android:layout_height="20dp"
        android:layout_marginHorizontal="4dp"
        android:background="@color/resolver_divider" />

      <Button
        android:id="@+id/button_always"
        style="?attr/buttonBarButtonStyle"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:enabled="false"
        android:text="@string/activity_resolver_use_always"
        android:textAllCaps="false"
        android:textAppearance="@style/Resolver.ButtonText" />
    </LinearLayout>

  </LinearLayout>

</com.tasomaniac.openwith.resolver.ResolverDrawerLayout>

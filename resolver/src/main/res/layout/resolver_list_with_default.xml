<?xml version="1.0" encoding="utf-8"?>
<com.tasomaniac.openwith.resolver.ResolverDrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/contentPanel"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  app:maxCollapsedHeight="144dp"
  app:resolverMaxWidth="@dimen/resolver_max_width">

  <!-- Drag handle + link info + preferred item -->
  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_shape"
    android:orientation="vertical"
    app:layout_alwaysShow="true">

    <!-- Drag handle -->
    <View
      android:layout_width="36dp"
      android:layout_height="4dp"
      android:layout_gravity="center_horizontal"
      android:layout_marginTop="8dp"
      android:layout_marginBottom="4dp"
      android:background="@drawable/resolver_drag_handle" />

    <include layout="@layout/resolver_link_info" />

    <!-- Preferred app item -->
    <LinearLayout
      android:id="@+id/preferred_item"
      android:layout_width="match_parent"
      android:layout_height="56dp"
      android:foreground="?selectableItemBackground"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingHorizontal="24dp">

      <ImageView
        android:id="@+id/icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter" />

      <TextView
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:gravity="start|center_vertical"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="16sp"
        android:textStyle="bold" />
    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
      android:id="@+id/button_bar"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:paddingHorizontal="16dp"
      android:paddingTop="4dp"
      android:paddingBottom="8dp"
      android:visibility="gone"
      app:layout_alwaysShow="true">

      <Button
        android:id="@+id/button_once"
        style="?attr/buttonBarButtonStyle"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:maxLines="2"
        android:text="@string/activity_resolver_use_once"
        android:textAllCaps="false"
        android:textAppearance="@style/Resolver.ButtonText" />

      <!-- Vertical separator between buttons -->
      <View
        android:layout_width="1dp"
        android:layout_height="20dp"
        android:layout_marginHorizontal="4dp"
        android:background="@color/resolver_divider" />

      <Button
        android:id="@+id/button_always"
        style="?attr/buttonBarButtonStyle"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:maxLines="2"
        android:text="@string/activity_resolver_use_always"
        android:textAllCaps="false"
        android:textAppearance="@style/Resolver.ButtonText" />
    </LinearLayout>

    <!-- Divider -->
    <View
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:layout_marginHorizontal="16dp"
      android:background="@color/resolver_divider" />
  </LinearLayout>

  <!-- Other apps list -->
  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/resolver_list"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/resolver_background"
    android:clipToPadding="false"
    android:divider="@null"
    android:paddingBottom="8dp"
    android:scrollbarStyle="outsideOverlay"
    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
    android:orientation="vertical" />

</com.tasomaniac.openwith.resolver.ResolverDrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:installLocation="auto">

  <!-- Courtesy of https://github.com/TrianguloY/URLCheck/blob/master/app/src/main/AndroidManifest.xml -->
  <queries>
    <intent>
      <action android:name="*" />
    </intent>
  </queries>

  <!-- Force remove some permissions -->
  <uses-permission
    android:name="android.permission.READ_PHONE_STATE"
    tools:node="remove" />
  <!-- We can ignore the ScopedStorage warnings because we're removing the permissions -->
  <uses-permission
    android:name="android.permission.WRITE_EXTERNAL_STORAGE"
    tools:ignore="ScopedStorage"
    tools:node="remove" />
  <uses-permission
    android:name="android.permission.READ_EXTERNAL_STORAGE"
    tools:node="remove"
    tools:ignore="ScopedStorage" />

  <application
    android:name=".App"
    android:allowBackup="true"
    android:fullBackupContent="true"
    android:icon="@mipmap/ic_launcher_main"
    android:label="@string/app_name"
    android:roundIcon="@mipmap/ic_launcher_main"
    android:supportsRtl="true"
    android:theme="@style/Theme.OpenWith"
    android:localeConfig="@xml/locales_config"
    tools:ignore="GoogleAppIndexingWarning">

    <meta-data
      android:name="theming-meta"
      android:value="meta_998_sesl_app" />

    <activity
      android:name=".settings.SettingsActivity"
      android:clearTaskOnLaunch="true"
      android:exported="true"
      android:launchMode="singleInstance">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />

        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>

    <activity
      android:name=".preferred.PreferredAppsActivity"
      android:label="@string/title_preferred_apps"
      android:launchMode="singleInstance"
      android:parentActivityName=".settings.SettingsActivity" />

    <activity
      android:name=".browser.PreferredBrowserActivity"
      android:label="@string/browser_title"
      android:launchMode="singleInstance"
      android:parentActivityName=".settings.SettingsActivity" />

    <activity
      android:name=".settings.advanced.features.ToggleFeatureActivity"
      android:launchMode="singleInstance" />

    <activity
      android:name=".ShareToOpenWith"
      android:configChanges="keyboardHidden|orientation|screenLayout"
      android:documentLaunchMode="never"
      android:excludeFromRecents="true"
      android:exported="true"
      android:finishOnCloseSystemDialogs="true"
      android:label="@string/open_with"
      android:relinquishTaskIdentity="true"
      android:theme="@style/Theme.Transparent.NoAnimation"
      android:windowSoftInputMode="stateAlwaysHidden|adjustResize">

      <intent-filter android:label="@string/open_with">
        <action android:name="android.intent.action.SEND" />

        <category android:name="android.intent.category.DEFAULT" />

        <data android:mimeType="text/plain" />
      </intent-filter>

      <meta-data
        android:name="android.service.chooser.chooser_target_service"
        android:value="androidx.sharetarget.ChooserTargetServiceCompat" />

      <meta-data
        android:name="android.app.shortcuts"
        android:resource="@xml/shortcuts" />
    </activity>

    <activity-alias
      android:name=".TextSelectionActivity"
      android:enabled="true"
      android:exported="true"
      android:label="@string/open_with"
      android:targetActivity=".ShareToOpenWith">

      <intent-filter>
        <action android:name="android.intent.action.PROCESS_TEXT" />

        <category android:name="android.intent.category.DEFAULT" />

        <data android:mimeType="text/plain" />

      </intent-filter>
    </activity-alias>

    <activity-alias
      android:name=".BrowserActivity"
      android:enabled="false"
      android:exported="true"
      android:label="@string/open_with"
      android:targetActivity=".ShareToOpenWith">

      <intent-filter>
        <action android:name="android.intent.action.VIEW" />

        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />

        <data android:scheme="https" />
        <data android:scheme="http" />

      </intent-filter>
    </activity-alias>

    <activity-alias
      android:name=".SocialLinksActivity"
      android:enabled="true"
      android:exported="true"
      android:label="@string/open_with"
      android:targetActivity=".ShareToOpenWith">

      <intent-filter>
        <action android:name="android.intent.action.VIEW" />

        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />

        <!-- X / Twitter -->
        <data android:scheme="https" android:host="x.com" />
        <data android:scheme="https" android:host="*.x.com" />
        <data android:scheme="https" android:host="twitter.com" />
        <data android:scheme="https" android:host="*.twitter.com" />

        <!-- YouTube -->
        <data android:scheme="https" android:host="youtube.com" />
        <data android:scheme="https" android:host="*.youtube.com" />
        <data android:scheme="https" android:host="youtu.be" />

        <!-- Instagram -->
        <data android:scheme="https" android:host="instagram.com" />
        <data android:scheme="https" android:host="*.instagram.com" />

        <!-- Reddit -->
        <data android:scheme="https" android:host="reddit.com" />
        <data android:scheme="https" android:host="*.reddit.com" />
        <data android:scheme="https" android:host="redd.it" />

        <!-- TikTok -->
        <data android:scheme="https" android:host="tiktok.com" />
        <data android:scheme="https" android:host="*.tiktok.com" />

        <!-- Facebook -->
        <data android:scheme="https" android:host="facebook.com" />
        <data android:scheme="https" android:host="*.facebook.com" />

        <!-- LinkedIn -->
        <data android:scheme="https" android:host="linkedin.com" />
        <data android:scheme="https" android:host="*.linkedin.com" />

        <!-- GitHub -->
        <data android:scheme="https" android:host="github.com" />
        <data android:scheme="https" android:host="*.github.com" />

      </intent-filter>
    </activity-alias>

    <activity-alias
      android:name=".MediaLinksActivity"
      android:enabled="true"
      android:exported="true"
      android:label="@string/open_with"
      android:targetActivity=".ShareToOpenWith">

      <!-- URL + MIME type (scheme と mimeType を組み合わせた形式 - Chmate 等が MIME type を設定する場合) -->
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />

        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />

        <data android:scheme="https" android:mimeType="video/*" />
        <data android:scheme="http"  android:mimeType="video/*" />
        <data android:scheme="https" android:mimeType="audio/*" />
        <data android:scheme="http"  android:mimeType="audio/*" />
      </intent-filter>

      <!-- URL path pattern (MIME type が設定されない場合のフォールバック) -->
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />

        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />

        <data android:scheme="https" android:pathPattern=".*\\.mp4" />
        <data android:scheme="https" android:pathPattern=".*\\.mkv" />
        <data android:scheme="https" android:pathPattern=".*\\.webm" />
        <data android:scheme="https" android:pathPattern=".*\\.mov" />
        <data android:scheme="https" android:pathPattern=".*\\.mp3" />
        <data android:scheme="https" android:pathPattern=".*\\.m4a" />
        <data android:scheme="https" android:pathPattern=".*\\.flac" />
        <data android:scheme="http"  android:pathPattern=".*\\.mp4" />
        <data android:scheme="http"  android:pathPattern=".*\\.mkv" />
        <data android:scheme="http"  android:pathPattern=".*\\.webm" />
        <data android:scheme="http"  android:pathPattern=".*\\.mp3" />
        <data android:scheme="http"  android:pathPattern=".*\\.m4a" />
      </intent-filter>

      <!-- content / file URI (ファイルマネージャー等) -->
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />

        <category android:name="android.intent.category.DEFAULT" />

        <data android:scheme="content" android:mimeType="video/*" />
        <data android:scheme="content" android:mimeType="audio/*" />
        <data android:scheme="file"    android:mimeType="video/*" />
        <data android:scheme="file"    android:mimeType="audio/*" />
      </intent-filter>

    </activity-alias>

    <activity
      android:name=".redirect.RedirectFixActivity"
      android:configChanges="keyboardHidden|orientation|screenLayout"
      android:documentLaunchMode="never"
      android:excludeFromRecents="true"
      android:finishOnCloseSystemDialogs="true"
      android:relinquishTaskIdentity="true"
      android:theme="@style/BottomSheet.Light" />

  </application>

</manifest>
